# Echo AI Configuration
# Copy this file to .env and fill in your values

# LLM Provider settings
ECHO_PROVIDER=ollama
ECHO_MODEL=qwen3:4b-instruct
ECHO_BASE_URL=http://localhost:11434
ECHO_TEMPERATURE=0.1

# Workspace settings
ECHO_WORKSPACE=/home/user/workspace

# Session settings
ECHO_SESSION_DIR=~/.echo-ai/sessions

# Agent settings
ECHO_MAX_ITERATIONS=50

# Network settings
ECHO_ALLOW_NETWORK=true

# API Keys (if using OpenAI or Anthropic)
# ANTHROPIC_API_KEY=sk-ant-...
# OPENAI_API_KEY=sk-...

# Search provider API keys
# BRAVE_SEARCH_API_KEY=BSA...

# Sentry error tracking (optional)
# SENTRY_DSN=https://your-key@sentry.io/your-project-id
# SENTRY_ENVIRONMENT=production
# SENTRY_RELEASE=0.1.0
