#!/bin/bash
# Agent Chat Launcher - Continuous chat mode

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
VENV_DIR="$SCRIPT_DIR/.venv"

if [ ! -d "$VENV_DIR" ]; then
    echo "Creating virtual environment..."
    python3 -m venv "$VENV_DIR"
    source "$VENV_DIR/bin/activate"
    pip install -e . anthropic openai httpx pyyaml rich >/dev/null 2>&1
else
    source "$VENV_DIR/bin/activate"
fi

exec python -m agentframework.chat "$@"
